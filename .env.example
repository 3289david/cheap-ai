# OpenRouter API Key (get from openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# Default model (any OpenRouter model)
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Server config
PORT=3000
HOST=0.0.0.0

# Web UI config
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Domain for subdomains (your VPS domain)
BASE_DOMAIN=localhost

# JWT secret for auth
JWT_SECRET=change-me-to-random-secret

# Projects directory (where user projects live)
PROJECTS_DIR=/var/cheap-ai/projects

# Database path
DB_PATH=/var/cheap-ai/cheap-ai.db

# Optional: Anthropic direct (fallback)
ANTHROPIC_API_KEY=

# Optional: site referrer for OpenRouter rankings
SITE_URL=http://localhost:3000
SITE_NAME=cheap-ai
